# ═══════════════════════════════════════════════════════════════════
# DARWIN - Evolutionary Tournament Trading Agent
# Environment Configuration for BNB HACK 2026
# ═══════════════════════════════════════════════════════════════════
# Copy this to .env and fill in keys. All services have free tiers.
# ═══════════════════════════════════════════════════════════════════

# -- NETWORK -------------------------------------------------------
NETWORK=bsc-testnet
DRY_RUN=true
DARWIN_INTERVAL_H=6
PORTFOLIO_START_USD=200

# -- COINMARKETCAP (Market Data) -----------------------------------
CMC_API_KEY=your_cmc_api_key_here

# -- GROQ (Fast LLM Inference - Primary) ---------------------------
GROQ_API_KEY=your_groq_api_key_here

# -- OPENROUTER (Deep LLM Reasoning - Fallback) ---------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -- GITHUB GIST (State Persistence) --------------------------------
GIST_ID=your_private_gist_id_here
GITHUB_TOKEN=your_github_token_here

# -- TWAK (Trust Wallet Agent Kit - Trade Execution) ----------------
TWAK_ACCESS_ID=your_twak_access_id_here
TWAK_HMAC_SECRET=your_twak_hmac_secret_here
AGENT_WALLET_KEY=your_agent_wallet_key_here

# -- OPENCLAWCASH (Wallet Operations) -------------------------------
AGENTWALLETAPI_KEY=your_agentwalletapi_key_here

# -- UPSTASH REDIS (Real-Time State) --------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# -- BSCSCAN (Gas Price & BSC Data) ---------------------------------
BSCSCAN_API_KEY=your_bscscan_api_key_here

# -- NEXT.JS (Vercel Dashboard) -------------------------------------
NEXT_PUBLIC_GIST_ID=your_gist_id_here

# -- AGENT WALLET (BSC Testnet) -------------------------------------
AGENT_WALLET_ADDRESS=0xYourWalletAddressHere
AGENT_WALLET_PRIVATE_KEY=your_private_key_here
