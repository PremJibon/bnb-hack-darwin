# DARWIN - Environment Configuration
# Copy to .env and fill in your keys

# CoinMarketCap API (free Basic plan)
CMC_API_KEY=your_cmc_api_key_here

# Groq API (free tier - llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API (free credits - for deep reasoning)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub Gist (for state persistence)
GIST_ID=your_gist_id_here
GITHUB_TOKEN=your_github_token_here

# TWAK (Trust Wallet Agent Kit)
TWAK_ACCESS_ID=your_twak_access_id
TWAK_HMAC_SECRET=your_twak_hmac_secret
AGENT_WALLET_KEY=your_agent_wallet_key

# DARWIN Settings
DRY_RUN=true
DARWIN_INTERVAL_H=6
PORTFOLIO_START_USD=200
